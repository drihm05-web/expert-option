{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (client or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "role": { "type": "string", "enum": ["client", "admin"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle available for export",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Vehicle title/name" },
        "brand": { "type": "string", "description": "Vehicle brand/make" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "mileage": { "type": "number" },
        "price": { "type": "number", "description": "Price in USD" },
        "images": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "Array of image URLs"
        },
        "condition": { "type": "string", "enum": ["New", "Used", "Refurbished"], "description": "Vehicle condition" },
        "status": { "type": "string", "enum": ["Available", "Reserved", "Sold"], "description": "Availability status" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "brand", "price", "images", "condition", "status", "createdAt"]
    },
    "ExportRequest": {
      "title": "Export Request",
      "description": "A request to export a vehicle",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "ID of the user making the request" },
        "vehicle_id": { "type": "string", "description": "ID of the requested vehicle (optional if custom sourcing)" },
        "destination": { "type": "string", "description": "Destination country" },
        "budget": { "type": "number", "description": "Estimated budget" },
        "preferences": { "type": "string", "description": "Additional preferences or notes" },
        "status": { "type": "string", "enum": ["Pending", "Sourcing", "Inspection", "Cleared", "Shipped", "Delivered"], "description": "Current status of the request" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "destination", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within an export request",
      "type": "object",
      "properties": {
        "request_id": { "type": "string", "description": "ID of the export request" },
        "user_id": { "type": "string", "description": "ID of the user sending the message" },
        "user_name": { "type": "string" },
        "user_role": { "type": "string" },
        "content": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["request_id", "user_id", "content", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A general inquiry or concierge request",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "In Progress", "Resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "name", "email", "message", "status", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global app settings",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      },
      "required": ["value"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Stores available vehicles"
    },
    "/export_requests/{requestId}": {
      "schema": { "$ref": "#/entities/ExportRequest" },
      "description": "Stores export requests"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages related to export requests"
    },
    "/inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/Inquiry" },
      "description": "Stores general inquiries"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Stores global settings"
    }
  }
}
